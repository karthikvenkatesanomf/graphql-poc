{
  "name": "graphql-bookstore-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL Bookstore Monorepo — NestJS API + React Client",
  "workspaces": [
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev:server": "npm run start:dev -w packages/server",
    "dev:client": "npm run dev -w packages/client",
    "build:server": "npm run build -w packages/server",
    "build:client": "npm run build -w packages/client",
    "build": "npm run build:server && npm run build:client",
    "start:server": "npm run start -w packages/server",
    "seed": "npm run seed -w packages/server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
